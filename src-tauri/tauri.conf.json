{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Nexus Island",
  "version": "0.2.0",
  "identifier": "com.nexus.island",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Nexus Island",
        "label": "island-panel",
        "width": 440,
        "height": 580,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": false,
        "resizable": true,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "visibleOnAllWorkspaces": true,
        "windowEffects": {
          "effects": ["blur"],
          "state": "active"
        }
      }
    ],
    "trayIcon": {
      "id": "nexus-tray",
      "iconPath": "icons/icon.png",
      "tooltip": "Nexus Island",
      "menuOnLeftClick": false,
      "title": "Nexus",
      "showMenuOnLeftClick": true
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ws://127.0.0.1:*; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
